{
  "manifest_version": 3,
  "name": "LUMEN Mind",
  "version": "1.0.0",
  "description": "Voice assistant for Chrome & Chromebook — Tesco search, scroll, open sites.",
  "permissions": ["tabs", "scripting", "storage", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "LUMEN Mind",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+L" },
      "description": "Open LUMEN side panel"
    }
  }
}
